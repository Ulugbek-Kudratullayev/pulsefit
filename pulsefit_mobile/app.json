{
  "expo": {
    "name": "PulseFit",
    "slug": "pulsefit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pulsefit",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "uz.pulsefit.app",
      "infoPlist": {
        "NSMotionUsageDescription": "Qadamlaringizni hisoblash uchun harakat sensori kerak",
        "NSCameraUsageDescription": "Profil rasmini olish uchun kamera kerak",
        "NSPhotoLibraryUsageDescription": "Profil rasmini tanlash uchun galereya kerak"
      }
    },
    "android": {
      "package": "uz.pulsefit.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "permissions": ["ACTIVITY_RECOGNITION", "BODY_SENSORS"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B35"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "http://10.0.2.2:8000/api/v1"
    }
  }
}
